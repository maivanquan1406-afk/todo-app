# Environment Variables
# Copy this file to .env and fill in your values

# Environment (development or production)
ENVIRONMENT=development

# Application metadata
APP_NAME=Task Manager
APP_DOMAIN=http://127.0.0.1:8000

# Server Port (Railway sets this automatically)
PORT=8000

# Database
# For local development with SQLite:
# DATABASE_URL=sqlite:///./todo.db

# For Railway PostgreSQL (provided automatically):
# DATABASE_URL=postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./todo.db

# JWT Secret Key (generate with: python generate_config.py --secret-key)
# Change this in production!
SECRET_KEY=your-secret-key-here-change-this-in-production

# SMTP (use Gmail App Password when 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=Task Manager <your_gmail_address@gmail.com>
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Allowed Hosts (comma-separated, for production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Gunicorn Workers (for production)
GUNICORN_WORKERS=4

